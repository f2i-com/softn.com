  <Box className="poker-host-controls" if={isHost && mySeat >= 0} style={{
    position: "absolute", bottom: hostControlsBottomStyle(), left: "50%", transform: "translateX(-50%)", zIndex: 60,
    display: "flex", gap: "10px", alignItems: "center", flexWrap: "wrap", justifyContent: "center",
    width: "min(94vw, 640px)"
  }}>
    <Button if={gamePhase === "waiting" && countSeatedPlayers() >= 2} @click={startHand} style={{
      background: "linear-gradient(135deg, #c8aa6e, #a08040)", color: "#1c1917", border: "none",
      borderRadius: "10px", padding: "12px 32px", fontSize: "16px", fontWeight: "700",
      cursor: "pointer", boxShadow: "0 4px 16px rgba(200,170,110,0.3)"
    }}>
      Deal Cards
    </Button>
    <Button if={(gamePhase === "waiting" || gamePhase === "showdown") && countSeatedPlayers() < 6} @click={addBot} style={{
      background: "rgba(255,255,255,0.1)", color: "rgba(255,255,255,0.8)", border: "1px solid rgba(255,255,255,0.2)",
      borderRadius: "10px", padding: "10px 20px", fontSize: "13px", fontWeight: "600",
      cursor: "pointer"
    }}>
      + Add Bot
    </Button>
  </Box>

  // Rebuy button (when player is out of chips between hands)
  <Box className="poker-rebuy" if={canRebuy()} style={{
    position: "absolute", bottom: rebuyBottomStyle(), left: "50%", transform: "translateX(-50%)", zIndex: 60
  }}>
    <Button @click={rebuy} style={{
      background: "linear-gradient(135deg, #22c55e, #16a34a)", color: "#fff", border: "none",
      borderRadius: "10px", padding: "10px 24px", fontSize: "14px", fontWeight: "700",
      cursor: "pointer", boxShadow: "0 4px 16px rgba(34,197,94,0.3)"
    }}>
      Rebuy $1000
    </Button>
  </Box>

  // Action panel
  <ActionPanel />

  // Host debug overlay
  <Box if={isHost && showDebugOverlay} style={{
    position: "absolute", top: "58px", right: "12px", zIndex: 200,
    width: "min(88vw, 350px)", maxHeight: "50vh", overflowY: "auto",
    background: "rgba(0,0,0,0.78)", backdropFilter: "blur(10px)",
    border: "1px solid rgba(255,255,255,0.16)", borderRadius: "10px", padding: "10px"
  }}>
    <Box style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: "6px" }}>
      <Text style={{ color: "#22c55e", fontSize: "12px", fontWeight: "800" }}>Host Debug</Text>
      <Button @click={copyDebugSnapshot} style={{ background: "rgba(59,130,246,0.2)", color: "#93c5fd", border: "1px solid rgba(147,197,253,0.35)", borderRadius: "6px", padding: "2px 8px", fontSize: "10px", fontWeight: "700", cursor: "pointer" }}>Copy Debug</Button>
    </Box>
    <Text style={{ color: "rgba(255,255,255,0.75)", fontSize: "clamp(10px, 1.5vw, 11px)" }}>{"Phase: " + gamePhase + " | Hand: " + handNumber}</Text>
    <Text style={{ color: "rgba(255,255,255,0.75)", fontSize: "clamp(10px, 1.5vw, 11px)" }}>{"Turn seat: " + currentTurnSeat + " | Current bet: " + currentBet}</Text>
    <Text style={{ color: "rgba(255,255,255,0.75)", fontSize: "clamp(10px, 1.5vw, 11px)" }}>{"Min raise increment: " + getMinRaise() + " | Last full raise: " + lastFullRaise}</Text>
    <Text style={{ color: "rgba(255,255,255,0.75)", fontSize: "clamp(10px, 1.5vw, 11px)" }}>{"Pot: " + pot + " | Contributions: " + totalContributions()}</Text>
    <Text style={{ color: bankrollDelta() === 0 ? "rgba(134,239,172,0.9)" : "#fca5a5", fontSize: "clamp(10px, 1.5vw, 11px)" }}>{"Bankroll now: " + bankrollNow() + " | baseline: " + debugHandBankrollBaseline + " | delta: " + bankrollDelta()}</Text>
    <Text style={{ color: "rgba(255,255,255,0.7)", fontSize: "10px" }}>{"Sound diag: " + soundDiag}</Text>
    <Text if={soundLastError} style={{ color: "#fca5a5", fontSize: "10px" }}>{"Sound error: " + soundLastError}</Text>
    <Text style={{ color: debugTraceEnabled ? "#93c5fd" : "rgba(255,255,255,0.45)", fontSize: "10px", marginTop: "2px" }}>{"Trace: " + (debugTraceEnabled ? "ON" : "OFF")}</Text>
    <Text style={{ color: "rgba(255,255,255,0.55)", fontSize: "10px", marginTop: "6px", marginBottom: "4px" }}>Seat snapshots</Text>

    <Box if={seatHasPlayer(0)} style={{ padding: "4px 0", borderTop: "1px solid rgba(255,255,255,0.08)" }}>
      <Text style={{ color: "#fff", fontSize: "clamp(10px, 1.5vw, 11px)" }}>{"S1 " + seatName(0) + " | st:" + seatStatus(0) + " | chips:" + seatChips(0) + " | bet:" + seatBet(0) + " | contrib:" + seatContribution(0) + " | canAct:" + seatCanAct(0)}</Text>
    </Box>
    <Box if={!seatHasPlayer(0)} style={{ padding: "4px 0", borderTop: "1px solid rgba(255,255,255,0.08)" }}>
      <Text style={{ color: "rgba(255,255,255,0.45)", fontSize: "clamp(10px, 1.5vw, 11px)" }}>S1 empty</Text>
    </Box>
    <Box if={seatHasPlayer(1)} style={{ padding: "4px 0", borderTop: "1px solid rgba(255,255,255,0.08)" }}>
      <Text style={{ color: "#fff", fontSize: "clamp(10px, 1.5vw, 11px)" }}>{"S2 " + seatName(1) + " | st:" + seatStatus(1) + " | chips:" + seatChips(1) + " | bet:" + seatBet(1) + " | contrib:" + seatContribution(1) + " | canAct:" + seatCanAct(1)}</Text>
    </Box>
    <Box if={!seatHasPlayer(1)} style={{ padding: "4px 0", borderTop: "1px solid rgba(255,255,255,0.08)" }}>
      <Text style={{ color: "rgba(255,255,255,0.45)", fontSize: "clamp(10px, 1.5vw, 11px)" }}>S2 empty</Text>
    </Box>
    <Box if={seatHasPlayer(2)} style={{ padding: "4px 0", borderTop: "1px solid rgba(255,255,255,0.08)" }}>
      <Text style={{ color: "#fff", fontSize: "clamp(10px, 1.5vw, 11px)" }}>{"S3 " + seatName(2) + " | st:" + seatStatus(2) + " | chips:" + seatChips(2) + " | bet:" + seatBet(2) + " | contrib:" + seatContribution(2) + " | canAct:" + seatCanAct(2)}</Text>
    </Box>
    <Box if={!seatHasPlayer(2)} style={{ padding: "4px 0", borderTop: "1px solid rgba(255,255,255,0.08)" }}>
      <Text style={{ color: "rgba(255,255,255,0.45)", fontSize: "clamp(10px, 1.5vw, 11px)" }}>S3 empty</Text>
    </Box>
    <Box if={seatHasPlayer(3)} style={{ padding: "4px 0", borderTop: "1px solid rgba(255,255,255,0.08)" }}>
      <Text style={{ color: "#fff", fontSize: "clamp(10px, 1.5vw, 11px)" }}>{"S4 " + seatName(3) + " | st:" + seatStatus(3) + " | chips:" + seatChips(3) + " | bet:" + seatBet(3) + " | contrib:" + seatContribution(3) + " | canAct:" + seatCanAct(3)}</Text>
    </Box>
    <Box if={!seatHasPlayer(3)} style={{ padding: "4px 0", borderTop: "1px solid rgba(255,255,255,0.08)" }}>
      <Text style={{ color: "rgba(255,255,255,0.45)", fontSize: "clamp(10px, 1.5vw, 11px)" }}>S4 empty</Text>
    </Box>
    <Box if={seatHasPlayer(4)} style={{ padding: "4px 0", borderTop: "1px solid rgba(255,255,255,0.08)" }}>
      <Text style={{ color: "#fff", fontSize: "clamp(10px, 1.5vw, 11px)" }}>{"S5 " + seatName(4) + " | st:" + seatStatus(4) + " | chips:" + seatChips(4) + " | bet:" + seatBet(4) + " | contrib:" + seatContribution(4) + " | canAct:" + seatCanAct(4)}</Text>
    </Box>
    <Box if={!seatHasPlayer(4)} style={{ padding: "4px 0", borderTop: "1px solid rgba(255,255,255,0.08)" }}>
      <Text style={{ color: "rgba(255,255,255,0.45)", fontSize: "clamp(10px, 1.5vw, 11px)" }}>S5 empty</Text>
    </Box>
    <Box if={seatHasPlayer(5)} style={{ padding: "4px 0", borderTop: "1px solid rgba(255,255,255,0.08)" }}>
      <Text style={{ color: "#fff", fontSize: "clamp(10px, 1.5vw, 11px)" }}>{"S6 " + seatName(5) + " | st:" + seatStatus(5) + " | chips:" + seatChips(5) + " | bet:" + seatBet(5) + " | contrib:" + seatContribution(5) + " | canAct:" + seatCanAct(5)}</Text>
    </Box>
    <Box if={!seatHasPlayer(5)} style={{ padding: "4px 0", borderTop: "1px solid rgba(255,255,255,0.08)" }}>
      <Text style={{ color: "rgba(255,255,255,0.45)", fontSize: "clamp(10px, 1.5vw, 11px)" }}>S6 empty</Text>
    </Box>
  </Box>
</Box>

















