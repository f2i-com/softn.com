{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "android",
  "description": "Android capabilities for SoftN Loader",
  "platforms": ["android"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-appcache-read",
    "fs:allow-appcache-write"
  ]
}
