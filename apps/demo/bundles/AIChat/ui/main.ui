// main.ui - AI Chat
// Qwen3.5-0.8B local chat · responsive layout

<logic src="../logic/main.logic" />

<style>
/* ── Animations ── */
@keyframes dot-bounce {
  0%, 80%, 100% { transform: translateY(0); }
  40% { transform: translateY(-5px); }
}
@keyframes msg-in {
  from { opacity: 0; transform: translateY(6px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes sidebar-slide {
  from { transform: translateX(-100%); }
  to { transform: translateX(0); }
}
@keyframes backdrop-in {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes pulse-glow {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}
@keyframes fade-up {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.msg-enter { animation: msg-in 0.2s ease-out; }
.dot-1 { animation: dot-bounce 1.4s ease-in-out infinite; }
.dot-2 { animation: dot-bounce 1.4s ease-in-out 0.2s infinite; }
.dot-3 { animation: dot-bounce 1.4s ease-in-out 0.4s infinite; }
.pulse { animation: pulse-glow 2s ease-in-out infinite; }
.fade-up { animation: fade-up 0.4s ease-out; }
.fade-up-delay { animation: fade-up 0.4s 0.08s ease-out both; }
.fade-up-delay2 { animation: fade-up 0.4s 0.16s ease-out both; }
.fade-up-delay3 { animation: fade-up 0.4s 0.24s ease-out both; }

/* ── Sidebar ── */
.sidebar {
  width: 260px;
  min-width: 260px;
  display: flex;
  flex-direction: column;
  border-right: 1px solid rgba(255,255,255,0.06);
  background: #0c0c15;
  z-index: 20;
}
.sidebar-item {
  padding: 0.5rem 0.75rem;
  border-radius: 8px;
  cursor: pointer;
  transition: all 120ms ease;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 1px;
}
.sidebar-item:hover { background: rgba(255,255,255,0.04); }
.sidebar-item .del-btn { opacity: 0; transition: opacity 120ms; }
.sidebar-item:hover .del-btn { opacity: 0.6; }

/* ── Chat bubbles ── */
.bubble-user {
  background: linear-gradient(135deg, #065f46, #064e3b);
  border-radius: 18px 18px 4px 18px;
  padding: 0.625rem 0.9375rem;
  color: #d1fae5;
  font-size: 0.8125rem;
  line-height: 1.65;
  white-space: pre-wrap;
  word-break: break-word;
  max-width: 72%;
  box-shadow: 0 1px 4px rgba(0,0,0,0.15);
}
.bubble-ai {
  background: rgba(255,255,255,0.025);
  border: 1px solid rgba(255,255,255,0.045);
  border-radius: 18px 18px 18px 4px;
  padding: 0.625rem 0.9375rem;
  color: #d0d0e4;
  font-size: 0.8125rem;
  line-height: 1.65;
  white-space: pre-wrap;
  word-break: break-word;
  max-width: 72%;
}

/* ── Input ── */
.input-container {
  background: #111120;
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 16px;
  display: flex;
  align-items: flex-end;
  padding: 0.25rem 0.25rem 0.25rem 0.375rem;
  transition: border-color 200ms;
  box-shadow: 0 2px 8px rgba(0,0,0,0.12);
}
.input-container:focus-within {
  border-color: rgba(16,185,129,0.35);
  box-shadow: 0 2px 12px rgba(16,185,129,0.06);
}

/* ── Send button ── */
.send-btn {
  width: 34px;
  height: 34px;
  border-radius: 10px;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  flex-shrink: 0;
  transition: all 180ms ease;
  min-width: auto;
  padding: 0;
}
.send-btn:hover {
  transform: scale(1.05);
}

/* ── Suggestion cards ── */
.suggestion-card {
  background: rgba(255,255,255,0.025);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 14px;
  padding: 1rem 1.25rem;
  cursor: pointer;
  transition: all 180ms ease;
  flex: 1;
  min-width: 140px;
  max-width: 200px;
}
.suggestion-card:hover {
  background: rgba(16,185,129,0.06);
  border-color: rgba(16,185,129,0.15);
  transform: translateY(-1px);
}

/* ── Image attachment ── */
.attach-preview {
  position: relative;
  display: inline-flex;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.08);
}
.attach-preview img {
  width: 56px;
  height: 56px;
  object-fit: cover;
  display: block;
}
.attach-remove {
  position: absolute;
  top: 2px;
  right: 2px;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: rgba(0,0,0,0.7);
  color: #fff;
  font-size: 0.6rem;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  border: none;
  line-height: 1;
}

.msg-image img {
  max-width: 200px;
  max-height: 150px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.06);
  display: block;
}

/* ── Attach button ── */
.attach-btn {
  padding: 0.375rem;
  min-width: 34px;
  height: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  transition: all 150ms ease;
  font-weight: 300;
}
.attach-btn:hover {
  background: rgba(255,255,255,0.04);
  color: #10b981 !important;
}

/* ── Scrollbars ── */
.scroll-thin::-webkit-scrollbar { width: 4px; }
.scroll-thin::-webkit-scrollbar-track { background: transparent; }
.scroll-thin::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.06); border-radius: 4px; }
.scroll-thin::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.12); }

/* ── Backdrop (mobile sidebar overlay) ── */
.backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 15;
  animation: backdrop-in 0.15s ease-out;
}

/* ── Mobile responsive ── */
@media (max-width: 639px) {
  .sidebar {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 280px;
    min-width: 280px;
    animation: sidebar-slide 0.2s ease-out;
    box-shadow: 4px 0 24px rgba(0,0,0,0.4);
  }
  .bubble-user, .bubble-ai {
    max-width: 88%;
    font-size: 0.875rem;
  }
  .msg-image img {
    max-width: 180px;
  }
  .attach-preview img {
    width: 48px;
    height: 48px;
  }
  .suggestion-card {
    min-width: 120px;
    padding: 0.75rem;
  }
}
</style>

<App theme="dark">
  <Box style={{
    display: "flex",
    width: "100%",
    height: "100%",
    overflow: "hidden",
    background: "#09090f",
    position: "relative",
    fontFamily: "-apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif"
  }}>

    // ═══════ MOBILE BACKDROP ═══════
    <Box if={showSidebar && isMobile} className="backdrop" @click={closeSidebar} />

    // ═══════ SIDEBAR ═══════
    <Box if={showSidebar} className="sidebar">
      // Header
      <Box style={{
        padding: "0.75rem",
        display: "flex",
        alignItems: "center",
        gap: "0.625rem",
        borderBottom: "1px solid rgba(255,255,255,0.05)"
      }}>
        <Box style={{
          width: "30px",
          height: "30px",
          borderRadius: "9px",
          background: "linear-gradient(135deg, #10b981, #047857)",
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          flexShrink: 0
        }}>
          <Text style={{ color: "#fff", fontSize: "0.6875rem", fontWeight: 700 }}>AI</Text>
        </Box>
        <Text style={{ fontSize: "0.875rem", fontWeight: 600, color: "#e4e4ed", flex: 1 }}>AI Chat</Text>
        // Close sidebar on mobile
        <Button if={isMobile} variant=ghost @click={closeSidebar} style={{
          padding: "4px 8px",
          color: "#666",
          minWidth: "auto",
          fontSize: "1rem"
        }}>x</Button>
      </Box>

      // New chat button
      <Box style={{ padding: "0.5rem 0.625rem" }}>
        <Button @click={newConversation} style={{
          width: "100%",
          background: "rgba(16,185,129,0.1)",
          color: "#10b981",
          border: "1px solid rgba(16,185,129,0.15)",
          borderRadius: "8px",
          padding: "0.5rem",
          fontSize: "0.8125rem",
          fontWeight: 500,
          cursor: "pointer",
          display: "flex",
          alignItems: "center",
          justifyContent: "center",
          gap: "0.375rem"
        }}>+ New Chat</Button>
      </Box>

      // Conversation list
      <Box className="scroll-thin" style={{
        flex: 1,
        overflowY: "auto",
        padding: "0.25rem 0.5rem"
      }}>
        #each (conv in conversations)
          <Box className="sidebar-item" @click={selectConversation(conv)} style={{
            background: isActiveConv(conv) ? "rgba(16,185,129,0.08)" : "transparent"
          }}>
            <Box style={{
              width: "5px",
              height: "5px",
              borderRadius: "50%",
              background: isActiveConv(conv) ? "#10b981" : "transparent",
              flexShrink: 0
            }} />
            <Box style={{ flex: 1, minWidth: 0 }}>
              <Text style={{
                fontSize: "0.8125rem",
                color: isActiveConv(conv) ? "#d1fae5" : "#8888a0",
                whiteSpace: "nowrap",
                overflow: "hidden",
                textOverflow: "ellipsis",
                fontWeight: isActiveConv(conv) ? 500 : 400,
                display: "block"
              }}>{getConvTitle(conv)}</Text>
            </Box>
            <Text style={{
              fontSize: "0.625rem",
              color: "#444",
              flexShrink: 0,
              whiteSpace: "nowrap"
            }}>{getConvTime(conv)}</Text>
            <Button className="del-btn" variant=ghost @click={deleteConversation(conv.id)} style={{
              padding: "2px 4px",
              fontSize: "0.625rem",
              color: "#555",
              flexShrink: 0,
              minWidth: "auto"
            }}>x</Button>
          </Box>
        #empty
          <Box style={{ padding: "2.5rem 1rem", textAlign: "center" }}>
            <Text style={{ fontSize: "0.75rem", color: "#3a3a50", lineHeight: 1.6 }}>
              No conversations yet
            </Text>
          </Box>
        #end
      </Box>

      // Settings
      <Box style={{ borderTop: "1px solid rgba(255,255,255,0.04)" }}>
        <Button variant=ghost @click={toggleSettings} style={{
          width: "100%",
          textAlign: "left",
          padding: "0.5rem 0.75rem",
          fontSize: "0.6875rem",
          color: "#555",
          display: "flex",
          alignItems: "center",
          gap: "0.375rem"
        }}>
          {showSettings ? "v" : ">"} Settings
        </Button>
        <Box if={showSettings} style={{ padding: "0 0.75rem 0.625rem" }}>
          <Stack direction=vertical gap=xs>
            <Stack direction=horizontal gap=xs align=center justify="space-between">
              <Text style={{ fontSize: "0.6875rem", color: "#555" }}>Temperature</Text>
              <Input value={temperature} @change={setTemperature} style={{
                width: "50px", background: "#0e0e1a", border: "1px solid rgba(255,255,255,0.06)",
                color: "#999", borderRadius: "5px", padding: "3px 6px", fontSize: "0.6875rem", textAlign: "center"
              }} />
            </Stack>
            <Stack direction=horizontal gap=xs align=center justify="space-between">
              <Text style={{ fontSize: "0.6875rem", color: "#555" }}>Max Tokens</Text>
              <Input value={maxTokens} @change={setMaxTokens} style={{
                width: "60px", background: "#0e0e1a", border: "1px solid rgba(255,255,255,0.06)",
                color: "#999", borderRadius: "5px", padding: "3px 6px", fontSize: "0.6875rem", textAlign: "center"
              }} />
            </Stack>
            <Stack direction=horizontal gap=xs align=center justify="space-between">
              <Text style={{ fontSize: "0.6875rem", color: "#555" }}>Top-P</Text>
              <Input value={topP} @change={setTopP} style={{
                width: "50px", background: "#0e0e1a", border: "1px solid rgba(255,255,255,0.06)",
                color: "#999", borderRadius: "5px", padding: "3px 6px", fontSize: "0.6875rem", textAlign: "center"
              }} />
            </Stack>
          </Stack>
        </Box>
      </Box>
    </Box>

    // ═══════ MAIN CHAT AREA ═══════
    <Box style={{
      flex: 1,
      display: "flex",
      flexDirection: "column",
      minWidth: 0,
      overflow: "hidden"
    }}>

      // ── Top bar ──
      <Box style={{
        display: "flex",
        alignItems: "center",
        justifyContent: "space-between",
        padding: "0.375rem 0.625rem",
        borderBottom: "1px solid rgba(255,255,255,0.04)",
        background: "#0b0b13",
        flexShrink: 0,
        minHeight: "42px",
        gap: "0.5rem"
      }}>
        // Left: hamburger + status
        <Stack direction=horizontal gap=sm align=center style={{ flex: 1, minWidth: 0 }}>
          <Button variant=ghost @click={toggleSidebar} style={{
            padding: "6px",
            color: "#666",
            minWidth: "32px",
            height: "32px",
            display: "flex",
            alignItems: "center",
            justifyContent: "center"
          }}>
            <Box style={{
              width: "16px",
              height: "12px",
              display: "flex",
              flexDirection: "column",
              justifyContent: "space-between"
            }}>
              <Box style={{ height: "1.5px", background: "#888", borderRadius: "1px" }} />
              <Box style={{ height: "1.5px", background: "#888", borderRadius: "1px", width: "70%" }} />
              <Box style={{ height: "1.5px", background: "#888", borderRadius: "1px" }} />
            </Box>
          </Button>

          <Box style={{
            width: "7px", height: "7px", borderRadius: "50%", flexShrink: 0,
            background: modelLoaded ? "#10b981" : modelLoading ? "#f59e0b" : "#555",
            boxShadow: modelLoaded ? "0 0 6px rgba(16,185,129,0.4)" : "none"
          }} />
          <Text style={{
            fontSize: "0.6875rem",
            color: "#555",
            whiteSpace: "nowrap",
            overflow: "hidden",
            textOverflow: "ellipsis"
          }}>{statusText}</Text>
        </Stack>

        // Right: model actions
        <Box style={{ flexShrink: 0 }}>
          <Button if={!modelLoaded && !modelLoading} @click={loadModel} style={{
            background: "linear-gradient(135deg, #10b981, #059669)",
            color: "#fff", border: "none", borderRadius: "8px",
            padding: "0.3rem 0.75rem", fontSize: "0.6875rem", fontWeight: 500
          }}>Load Model</Button>
          <Button if={modelLoading} style={{
            background: "#141425", color: "#f59e0b",
            border: "1px solid rgba(245,158,11,0.15)", borderRadius: "8px",
            padding: "0.3rem 0.75rem", fontSize: "0.6875rem", cursor: "wait"
          }}>Loading...</Button>
          <Button if={modelLoaded} variant=ghost @click={unloadModel} style={{
            fontSize: "0.625rem", color: "#555", padding: "0.3rem 0.5rem"
          }}>Unload</Button>
        </Box>
      </Box>

      // ── Messages ──
      <Box className="scroll-thin" style={{
        flex: 1, overflowY: "auto", padding: "0.75rem 0", minHeight: 0
      }}>

        // ─── Welcome state ───
        <Box if={chatMessages.length === 0} style={{
          display: "flex", flexDirection: "column", alignItems: "center",
          justifyContent: "center", height: "100%", gap: "1.5rem", padding: "2rem 1.5rem"
        }}>
          // Logo
          <Box className="fade-up" style={{
            width: "72px", height: "72px", borderRadius: "22px",
            background: "linear-gradient(135deg, #10b981 0%, #059669 50%, #047857 100%)",
            display: "flex", alignItems: "center", justifyContent: "center",
            boxShadow: "0 12px 40px rgba(16,185,129,0.2), 0 0 0 1px rgba(16,185,129,0.1)"
          }}>
            <Text style={{ color: "#fff", fontSize: "1.875rem", fontWeight: 700, letterSpacing: "-0.02em" }}>Q</Text>
          </Box>

          <Stack className="fade-up-delay" direction=vertical gap=xs align=center>
            <Text style={{ fontSize: "1.5rem", fontWeight: 600, color: "#e4e4ed", letterSpacing: "-0.02em" }}>Qwen3.5-0.8B</Text>
            <Text style={{
              fontSize: "0.8125rem", color: "#4a4a60", textAlign: "center",
              maxWidth: "360px", lineHeight: 1.7
            }}>
              A compact language model running entirely in your browser. Private, fast, and offline-capable.
            </Text>
          </Stack>

          // Suggestion cards (only show when model loaded + no conversation)
          <Box if={modelLoaded && !activeConversationId} className="fade-up-delay2" style={{
            display: "flex", flexWrap: "wrap", gap: "0.625rem", justifyContent: "center",
            maxWidth: "480px", marginTop: "0.25rem"
          }}>
            <Box className="suggestion-card" @click={startWithPrompt("Explain quantum computing in simple terms")}>
              <Text style={{ fontSize: "0.75rem", color: "#10b981", fontWeight: 500, marginBottom: "0.375rem", display: "block" }}>Explain</Text>
              <Text style={{ fontSize: "0.75rem", color: "#6a6a80", lineHeight: 1.5, display: "block" }}>Quantum computing in simple terms</Text>
            </Box>
            <Box className="suggestion-card" @click={startWithPrompt("Write a haiku about programming")}>
              <Text style={{ fontSize: "0.75rem", color: "#8b5cf6", fontWeight: 500, marginBottom: "0.375rem", display: "block" }}>Create</Text>
              <Text style={{ fontSize: "0.75rem", color: "#6a6a80", lineHeight: 1.5, display: "block" }}>Write a haiku about programming</Text>
            </Box>
            <Box className="suggestion-card" @click={startWithPrompt("What are the benefits of learning Rust?")}>
              <Text style={{ fontSize: "0.75rem", color: "#f59e0b", fontWeight: 500, marginBottom: "0.375rem", display: "block" }}>Discuss</Text>
              <Text style={{ fontSize: "0.75rem", color: "#6a6a80", lineHeight: 1.5, display: "block" }}>Benefits of learning Rust</Text>
            </Box>
            <Box className="suggestion-card" @click={startWithPrompt("Give me 5 fun facts about the ocean")}>
              <Text style={{ fontSize: "0.75rem", color: "#ec4899", fontWeight: 500, marginBottom: "0.375rem", display: "block" }}>Discover</Text>
              <Text style={{ fontSize: "0.75rem", color: "#6a6a80", lineHeight: 1.5, display: "block" }}>5 fun facts about the ocean</Text>
            </Box>
          </Box>

          // Load model CTA
          <Box if={!modelLoaded && !modelLoading} className="fade-up-delay2" style={{ marginTop: "0.25rem" }}>
            <Button @click={loadModel} style={{
              background: "linear-gradient(135deg, #10b981, #059669)",
              color: "#fff", border: "none", borderRadius: "12px",
              padding: "0.625rem 1.75rem", fontSize: "0.875rem", fontWeight: 500,
              boxShadow: "0 4px 20px rgba(16,185,129,0.25)"
            }}>Load Qwen3.5-0.8B (Q4)</Button>
          </Box>

          <Box if={modelLoading} className="fade-up-delay2" style={{ display: "flex", alignItems: "center", gap: "0.5rem" }}>
            <Box className="pulse" style={{
              width: "8px", height: "8px", borderRadius: "50%", background: "#f59e0b"
            }} />
            <Text style={{ fontSize: "0.8125rem", color: "#f59e0b" }}>Downloading model...</Text>
          </Box>
        </Box>

        // ─── Chat messages ───
        <Box if={chatMessages.length > 0} style={{
          display: "flex", flexDirection: "column", gap: "0.25rem"
        }}>
          #each (msg in chatMessages)
            // User message
            <Box if={isUserMsg(msg)} className="msg-enter" style={{
              display: "flex", flexDirection: "column", alignItems: "flex-end",
              padding: "0.25rem 1rem 0.25rem 2.5rem"
            }}>
              <Box if={hasImage(msg)} className="msg-image" style={{ marginBottom: "0.25rem" }}>
                <Image src={msg.data.imageDataUrl} alt="attached" borderRadius="md" />
              </Box>
              <Box if={hasContent(msg)} className="bubble-user">{msg.data.content}</Box>
              <Text style={{
                fontSize: "0.5625rem", color: "#3a3a50", marginTop: "0.2rem", paddingRight: "0.125rem"
              }}>{getMsgTime(msg)}</Text>
            </Box>

            // Assistant message
            <Box if={isAssistantMsg(msg)} className="msg-enter" style={{
              display: "flex", gap: "0.5rem", alignItems: "flex-start",
              padding: "0.375rem 2.5rem 0.375rem 1rem"
            }}>
              // Avatar
              <Box style={{
                width: "28px", height: "28px", borderRadius: "9px",
                background: "linear-gradient(135deg, #10b981, #059669)",
                display: "flex", alignItems: "center", justifyContent: "center",
                flexShrink: 0, marginTop: "2px"
              }}>
                <Text style={{ color: "#fff", fontSize: "0.5625rem", fontWeight: 700 }}>Q</Text>
              </Box>
              <Box style={{ minWidth: 0 }}>
                <Box className="bubble-ai">{msg.data.content}</Box>
                <Text style={{
                  fontSize: "0.5625rem", color: "#3a3a50", marginTop: "0.2rem", paddingLeft: "0.125rem"
                }}>{getMsgTime(msg)}</Text>
              </Box>
            </Box>
          #end

          // Generating indicator
          <Box if={generating} style={{
            display: "flex", gap: "0.5rem", alignItems: "flex-start",
            padding: "0.375rem 2.5rem 0.375rem 1rem"
          }}>
            <Box style={{
              width: "28px", height: "28px", borderRadius: "9px",
              background: "linear-gradient(135deg, #10b981, #059669)",
              display: "flex", alignItems: "center", justifyContent: "center",
              flexShrink: 0, marginTop: "2px"
            }}>
              <Text style={{ color: "#fff", fontSize: "0.5625rem", fontWeight: 700 }}>Q</Text>
            </Box>
            <Box className="bubble-ai" style={{
              display: "flex", gap: "5px", alignItems: "center", padding: "0.75rem 1rem"
            }}>
              <Box className="dot-1" style={{ width: "6px", height: "6px", borderRadius: "50%", background: "#10b981" }} />
              <Box className="dot-2" style={{ width: "6px", height: "6px", borderRadius: "50%", background: "#10b981" }} />
              <Box className="dot-3" style={{ width: "6px", height: "6px", borderRadius: "50%", background: "#10b981" }} />
            </Box>
          </Box>
        </Box>
      </Box>

      // ── Input area ──
      <Box if={activeConversationId || modelLoaded} style={{
        padding: "0.5rem 0.875rem 0.75rem", flexShrink: 0
      }}>
        // Attachment preview
        <Box if={attachedImage} style={{
          display: "flex", alignItems: "center", gap: "0.625rem",
          padding: "0.375rem 0.125rem", marginBottom: "0.25rem"
        }}>
          <Box className="attach-preview">
            <Image src={attachedImage} alt="attachment" width="56" height="56" objectFit="cover" />
            <Button className="attach-remove" @click={removeImage}>x</Button>
          </Box>
          <Text style={{ fontSize: "0.6875rem", color: "#666" }}>{attachedImageName}</Text>
        </Box>

        // Input bar
        <Box className="input-container">
          // Attach button — paperclip
          <Button variant=ghost className="attach-btn" @click={attachImage}>
            <Icon name="paperclip" size=18 color={attachedImage ? "#10b981" : "#555"} />
          </Button>

          // Text — wrapped in Box for flex stretch
          <Box style={{ flex: 1, minWidth: 0 }}>
            <TextArea
              value={inputText}
              @change={updateInput}
              placeholder={modelLoaded ? "Message Qwen3.5..." : "Load model to chat..."}
              rows=1
              autoResize={true}
              fullWidth={true}
              minHeight="36px"
              maxHeight="120px"
              resize="none"
              style={{
                background: "transparent", border: "none",
                color: "#e4e4ed", fontSize: "0.8125rem",
                padding: "0.5rem 0.25rem", lineHeight: 1.5, outline: "none",
                boxShadow: "none", width: "100%"
              }}
            />
          </Box>

          // Send button — paper plane
          <Button className="send-btn" @click={sendMessage} style={{
            background: canSend() ? "linear-gradient(135deg, #10b981, #059669)" : "rgba(255,255,255,0.04)",
            cursor: generating ? "wait" : "pointer",
            opacity: generating ? 0.5 : 1,
            boxShadow: canSend() ? "0 2px 8px rgba(16,185,129,0.25)" : "none"
          }}>
            <Icon name="send" size=16 color={canSend() ? "#fff" : "#3a3a50"} />
          </Button>
        </Box>

        <Text style={{
          fontSize: "0.5625rem", color: "#2a2a3a", textAlign: "center", marginTop: "0.5rem"
        }}>Runs locally in your browser via WebGPU/WASM</Text>
      </Box>
    </Box>
  </Box>
</App>
