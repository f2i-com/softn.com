  }

  function addAppointment(data) {
    db.create("appointments", {
      client: data.client,
      stylist: data.stylist,
      service: data.service,
      time: data.time,
      status: "scheduled",
      price: data.price || 0
    })
    logActivity("Appointment booked", data.client + " - " + data.service + " at " + data.time, "success")
    showAddModal = false
  }

  function editAppointment(row) {
    editingAppointment = row
    showEditAppointmentModal = true
  }

  function saveEditAppointment(data) {
    if (editingAppointment) {
      db.update(editingAppointment.id, {
        client: data.client || editingAppointment.data.client,
        stylist: data.stylist || editingAppointment.data.stylist,
        service: data.service || editingAppointment.data.service,
        time: data.time || editingAppointment.data.time,
        status: data.status || editingAppointment.data.status,
        price: data.price || editingAppointment.data.price
      })
      logActivity("Appointment updated", data.client + " appointment was updated", "info")
    }
    showEditAppointmentModal = false
    editingAppointment = null
  }

  function closeEditAppointmentModal() {
    showEditAppointmentModal = false
