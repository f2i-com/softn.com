// FileBrowser.ui - File chooser, file list, and content preview
// FileChooser component, file list display, file content preview

<Stack direction=vertical gap=lg if={currentPage === "files"}>
  // Header
  <Stack direction=vertical gap=sm>
    <Heading level={2} style={{ fontSize: "1.375rem", fontWeight: 600, color: "#0f172a" }}>File Browser</Heading>
    <Text style={{ color: "#64748b", fontSize: "0.875rem" }}>Select files from your device, browse metadata, and preview text content.</Text>
  </Stack>

  // File Chooser Card
  <Card padding=lg style={{ background: "#ffffff", borderRadius: "14px", border: "1px solid #e2e8f0" }}>
    <Stack direction=vertical gap=md>
      <Text fontWeight=semibold size=sm style={{ color: "#0f172a", textTransform: "uppercase", letterSpacing: "0.04em", fontSize: "0.75rem" }}>Select Files</Text>

      // File Chooser Component
      <Box style={{
        borderRadius: "12px",
        border: "2px dashed #cbd5e1",
        padding: "2rem",
        display: "flex",
        alignItems: "center",
        justifyContent: "center",
        background: "#f8fafc",
        cursor: "pointer"
      }}>
        <FileChooser onSelect={handleFileSelect} multiple={true} />
      </Box>
    </Stack>
  </Card>

  <Grid columns={{ sm: 1, lg: 2 }} gap=lg>
    // Selected Files List
    <Card padding=lg style={{ background: "#ffffff", borderRadius: "14px", border: "1px solid #e2e8f0" }}>
      <Stack direction=vertical gap=md>
        <Stack direction=horizontal justify="space-between" align=center>
          <Text fontWeight=semibold size=sm style={{ color: "#0f172a", textTransform: "uppercase", letterSpacing: "0.04em", fontSize: "0.75rem" }}>Selected Files</Text>
          <Badge variant=secondary size=sm>{selectedFiles.length + " files"}</Badge>
        </Stack>

        // File list display
        <Box if={selectedFiles.length > 0} style={{
          background: "#f8fafc",
          borderRadius: "10px",
          border: "1px solid #e2e8f0",
          overflow: "hidden"
        }}>
          #each (item in selectedFiles)
            <Box style={{
              padding: "0.75rem 1rem",
              borderBottom: "1px solid #f1f5f9",
              display: "flex",
              alignItems: "center",
              gap: "0.75rem"
            }}>
              <Box style={{
                width: "32px",
                height: "32px",
                borderRadius: "8px",
                background: "#eff6ff",
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
                flexShrink: 0
              }}>
                <Text size=xs style={{ color: "#3b82f6", fontWeight: 700 }}>F</Text>
              </Box>
              <Stack direction=vertical gap=xs style={{ flex: 1, minWidth: 0 }}>
                <Text size=sm fontWeight=medium style={{ color: "#0f172a", overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>{item.name}</Text>
                <Text size=xs style={{ color: "#94a3b8" }}>{item.type + " - " + item.size + " bytes"}</Text>
              </Stack>
            </Box>
          #end
        </Box>

        // No files placeholder
        <Box if={selectedFiles.length === 0} style={{
          background: "#f8fafc",
          borderRadius: "10px",
          padding: "2rem",
          border: "1px solid #e2e8f0",
          textAlign: "center"
        }}>
          <Text size=sm style={{ color: "#94a3b8" }}>No files selected. Use the file chooser above.</Text>
        </Box>
      </Stack>
    </Card>

    // File Content Preview
    <Card padding=lg style={{ background: "#ffffff", borderRadius: "14px", border: "1px solid #e2e8f0" }}>
      <Stack direction=vertical gap=md>
        <Text fontWeight=semibold size=sm style={{ color: "#0f172a", textTransform: "uppercase", letterSpacing: "0.04em", fontSize: "0.75rem" }}>File Content Preview</Text>

        // Image preview
        <Box if={fileIsImage && filePreviewUrl} style={{
          background: "#f8fafc",
          borderRadius: "10px",
          padding: "1rem",
          border: "1px solid #e2e8f0",
          maxHeight: "400px",
          overflow: "auto",
          display: "flex",
          alignItems: "center",
          justifyContent: "center"
        }}>
          <Image src={filePreviewUrl} alt="File preview" style={{
            maxWidth: "100%",
            maxHeight: "360px",
            borderRadius: "8px",
            objectFit: "contain"
          }} />
        </Box>

        // Text content display
        <Box if={!fileIsImage && fileContent} style={{
          background: "#f8fafc",
          borderRadius: "10px",
          padding: "1rem",
          border: "1px solid #e2e8f0",
          maxHeight: "400px",
          overflow: "auto"
        }}>
          <Text style={{
            fontFamily: "monospace",
            fontSize: "0.75rem",
            lineHeight: 1.6,
            color: "#334155",
            whiteSpace: "pre-wrap",
            wordBreak: "break-all"
          }}>{fileContent}</Text>
        </Box>

        // No content placeholder
        <Box if={!fileContent && !filePreviewUrl} style={{
          background: "#f8fafc",
          borderRadius: "10px",
          padding: "2rem",
          border: "1px solid #e2e8f0",
          textAlign: "center"
        }}>
          <Stack direction=vertical gap=sm align=center>
            <Box style={{
              width: "48px",
              height: "48px",
              borderRadius: "12px",
              background: "#e2e8f0",
              display: "flex",
              alignItems: "center",
              justifyContent: "center"
            }}>
              <Text style={{ fontSize: "1.25rem", color: "#94a3b8" }}>T</Text>
            </Box>
            <Text size=sm style={{ color: "#94a3b8" }}>No file content to preview</Text>
            <Text size=xs style={{ color: "#cbd5e1" }}>Select a text file to see its contents</Text>
          </Stack>
        </Box>
      </Stack>
    </Card>
  </Grid>

  // Permission Info
  <Card padding=md style={{ background: "#fefce8", borderRadius: "14px", border: "1px solid #fde68a" }}>
    <Stack direction=horizontal gap=sm align=center>
      <Text style={{ fontSize: "0.8125rem", color: "#92400e" }}>Permission: files.enabled with scopes ["user_selected"]. Only files explicitly chosen by the user can be accessed.</Text>
    </Stack>
  </Card>
</Stack>
