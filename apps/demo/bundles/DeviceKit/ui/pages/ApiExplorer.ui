// ApiExplorer.ui - Network API fetch demo
// Input for URL, fetch button, result display area

<Stack direction=vertical gap=lg if={currentPage === "api"}>
  // Header
  <Stack direction=vertical gap=sm>
    <Heading level={2} style={{ fontSize: "1.375rem", fontWeight: 600, color: "#0f172a" }}>API Explorer</Heading>
    <Text style={{ color: "#64748b", fontSize: "0.875rem" }}>Make HTTP requests using softn.net.fetch and view responses.</Text>
  </Stack>

  // Request Card
  <Card padding=lg style={{ background: "#ffffff", borderRadius: "14px", border: "1px solid #e2e8f0" }}>
    <Stack direction=vertical gap=md>
      <Text fontWeight=semibold size=sm style={{ color: "#0f172a", textTransform: "uppercase", letterSpacing: "0.04em", fontSize: "0.75rem" }}>Request</Text>

      // URL Input Row
      <Stack direction=horizontal gap=sm align=center>
        <Badge variant=info size=sm style={{ flexShrink: 0 }}>GET</Badge>
        <Input
          value={apiUrl}
          @change={updateApiUrl}
          placeholder="Enter API URL..."
          style={{
            flex: 1,
            padding: "0.625rem 0.875rem",
            borderRadius: "8px",
            border: "1px solid #e2e8f0",
            fontSize: "0.8125rem",
            fontFamily: "monospace"
          }}
        />
        <Button variant=primary @click={fetchApi()} style={{
          padding: "0.625rem 1.25rem",
          borderRadius: "8px",
          background: "linear-gradient(135deg, #3b82f6, #6366f1)",
          color: "#ffffff",
          fontWeight: 600,
          fontSize: "0.8125rem",
          flexShrink: 0
        }}>
          {apiLoading ? "Fetching..." : "Fetch"}
        </Button>
      </Stack>

      // Preset URLs
      <Stack direction=horizontal gap=sm style={{ flexWrap: "wrap" }}>
        <Text size=xs style={{ color: "#94a3b8", alignSelf: "center" }}>Presets:</Text>
        <Button variant=ghost size=sm @click={updateApiUrl("https://jsonplaceholder.typicode.com/todos/1")} style={{
          fontSize: "0.6875rem",
          padding: "0.25rem 0.625rem",
          borderRadius: "6px",
          background: "#f1f5f9",
          color: "#475569"
        }}>
          /todos/1
        </Button>
        <Button variant=ghost size=sm @click={updateApiUrl("https://jsonplaceholder.typicode.com/posts/1")} style={{
          fontSize: "0.6875rem",
          padding: "0.25rem 0.625rem",
          borderRadius: "6px",
          background: "#f1f5f9",
          color: "#475569"
        }}>
          /posts/1
        </Button>
        <Button variant=ghost size=sm @click={updateApiUrl("https://jsonplaceholder.typicode.com/users/1")} style={{
          fontSize: "0.6875rem",
          padding: "0.25rem 0.625rem",
          borderRadius: "6px",
          background: "#f1f5f9",
          color: "#475569"
        }}>
          /users/1
        </Button>
        <Button variant=ghost size=sm @click={updateApiUrl("https://jsonplaceholder.typicode.com/comments?postId=1")} style={{
          fontSize: "0.6875rem",
          padding: "0.25rem 0.625rem",
          borderRadius: "6px",
          background: "#f1f5f9",
          color: "#475569"
        }}>
          /comments?postId=1
        </Button>
      </Stack>
    </Stack>
  </Card>

  // Loading Indicator
  <Card padding=md if={apiLoading} style={{ background: "#eff6ff", borderRadius: "14px", border: "1px solid #bfdbfe" }}>
    <Stack direction=horizontal gap=sm align=center>
      <Text style={{ color: "#3b82f6", fontSize: "0.875rem" }}>Loading response...</Text>
    </Stack>
  </Card>

  // Response Card
  <Card padding=lg if={apiResult} style={{ background: "#ffffff", borderRadius: "14px", border: "1px solid #e2e8f0" }}>
    <Stack direction=vertical gap=md>
      <Stack direction=horizontal justify="space-between" align=center>
        <Text fontWeight=semibold size=sm style={{ color: "#0f172a", textTransform: "uppercase", letterSpacing: "0.04em", fontSize: "0.75rem" }}>Response</Text>
        <Badge variant=success size=sm>200 OK</Badge>
      </Stack>

      // Response Body
      <Box style={{
        background: "#f8fafc",
        borderRadius: "10px",
        padding: "1rem",
        border: "1px solid #e2e8f0",
        maxHeight: "400px",
        overflow: "auto"
      }}>
        <Text style={{
          fontFamily: "monospace",
          fontSize: "0.8125rem",
          lineHeight: 1.6,
          color: "#334155",
          whiteSpace: "pre-wrap",
          wordBreak: "break-all"
        }}>{apiResult}</Text>
      </Box>
    </Stack>
  </Card>

  // Permission Info
  <Card padding=md style={{ background: "#fefce8", borderRadius: "14px", border: "1px solid #fde68a" }}>
    <Stack direction=horizontal gap=sm align=center>
      <Text style={{ fontSize: "0.8125rem", color: "#92400e" }}>Permission: net.allowed_hosts includes "jsonplaceholder.typicode.com". Requests to other hosts will be blocked.</Text>
    </Stack>
  </Card>
</Stack>
