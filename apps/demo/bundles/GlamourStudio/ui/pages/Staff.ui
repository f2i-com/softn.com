// Staff.ui - Staff management page with list and detail views

<Stack direction=vertical gap=lg if={currentPage === "staff"}>
  // Detail View - shown when a staff member is selected
  <Stack direction=vertical gap=lg if={selectedItem}>
    <Button variant=ghost size=sm @click=clearSelection style={{ alignSelf: "flex-start", gap: "0.375rem", color: getAccentColor(), fontSize: "0.8rem" }}>
      ← Back to list
    </Button>

    // Staff Header Card
    <Card padding=lg style={{ background: darkMode ? "linear-gradient(135deg, #1c1917 0%, #292524 100%)" : "linear-gradient(135deg, #ffffff 0%, #faf9f7 100%)", borderRadius: "16px", border: "1px solid " + getBorderColor() }}>
      <Stack className="softn-mobile-stack" direction=horizontal gap=lg align=center style={{ flexWrap: "wrap" }}>
        <Avatar name={selectedItem.data.name} size=xl status={selectedItem.data.status} />
        <Stack direction=vertical gap=xs style={{ flex: 1, minWidth: 0 }}>
          <Heading level={3} style={{ fontSize: "1.25rem", fontFamily: "'Cormorant Garamond', serif" }}>{selectedItem.data.name}</Heading>
          <Text color=muted size=sm>{selectedItem.data.role}</Text>
          <Text color=muted size=xs>{selectedItem.data.email}</Text>
        </Stack>
        <Stack direction=vertical align=end gap=sm style={{ flexShrink: 0 }}>
          <Stack direction=horizontal gap=xs align=center>
            <Text size=lg fontWeight=bold style={{ color: getAccentColor(), fontFamily: "'Cormorant Garamond', serif" }}>{selectedItem.data.rating}</Text>
            <Text size=xs style={{ color: getMutedColor() }}>rating</Text>
          </Stack>
          <Text color=muted size=xs>{selectedItem.data.appointments + " appts today"}</Text>
        </Stack>
      </Stack>
    </Card>

    // Staff Details
    <Grid columns={{ sm: 1, md: 2 }} gap=lg>
      <SmartView data={selectedItem.data} fields="name, role, status, email" layout=card title="Profile Information" />
      <SmartView data={selectedItem.data} fields="appointments, rating" layout=card title="Performance Metrics" />
    </Grid>
  </Stack>

  // List View - shown when no staff is selected
  <Stack direction=vertical gap=lg if={!selectedItem}>
    <Card padding=md style={{ background: getCardBg(), borderRadius: "14px", border: "1px solid " + getBorderColor(), transition: "background 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1)", overflow: "auto" }}>
      <SmartGrid
        data={staff}
        columns="name, role, email, status, rating, appointments"
        searchable
        sortable
        pageable
        pageSize={10}
        editable
        delete
        onSelect={selectItem}
        onEdit={editStaff}
        onDelete={deleteStaff}
        emptyMessage="No staff members yet. Click '+ Staff' to add your first team member."
      />
    </Card>
  </Stack>
</Stack>
