{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SoftN Builder",
  "version": "0.1.0",
  "identifier": "com.softn.builder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SoftN Builder",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1024,
        "minHeight": 768,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["softnproj"],
        "name": "SoftN Project",
        "description": "SoftN Builder Project",
        "role": "Editor",
        "mimeType": "application/x-softn-project"
      }
    ]
  }
}
