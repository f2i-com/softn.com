// main.ui - SoftN Showcase
// Interactive demo of charts, animations, and drag/drop components

<logic src="../logic/main.logic" />

// Import components
<import Nav from="./components/Nav.ui" />

// Import pages
<import ChartsPage from="./pages/ChartsPage.ui" />
<import AnimationsPage from="./pages/AnimationsPage.ui" />
<import InteractivePage from="./pages/InteractivePage.ui" />

<style>
/* Custom scrollbar */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(99, 102, 241, 0.15); border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: rgba(99, 102, 241, 0.3); }

/* Focus rings */
*:focus-visible {
  outline: 2px solid rgba(99, 102, 241, 0.4);
  outline-offset: 2px;
}

/* NavItem active indicator */
.softn-nav-item { position: relative; transition: all 180ms ease; }
.softn-nav-item:hover { transform: translateX(2px); }
.softn-nav-item[data-active="true"]::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 3px;
  height: 60%;
  background: linear-gradient(180deg, #6366f1, #8b5cf6);
  border-radius: 0 3px 3px 0;
}

/* Card hover */
.softn-page-content [class*="card"] {
  transition: transform 200ms ease, box-shadow 200ms ease !important;
}

/* Mobile utilities */
.softn-mobile-only {
  display: none;
}

@media (max-width: 640px) {
  .softn-mobile-hide {
    display: none !important;
  }
  .softn-mobile-only {
    display: flex !important;
  }
  .softn-page-content {
    padding: 1rem !important;
  }
}
</style>

// Main App Layout
<App theme={darkMode ? "dark" : "light"}>
  <Box style={{ display: "flex", flexDirection: "column", width: "100%", height: "100%", overflow: "hidden", background: getBgColor() }}>
    // Mobile Top Nav
    <Box className="softn-mobile-only" style={{
      background: getSidebarBg(),
      borderBottom: "1px solid " + getBorderColor(),
      padding: "0.5rem",
      gap: "0",
      justifyContent: "center",
      flexShrink: 0
    }}>
      <Button variant=ghost @click={navigate("charts")} style={{
        flex: 1, padding: "0.5rem", borderRadius: 0, fontSize: "0.75rem", fontWeight: 600,
        color: currentPage === "charts" ? "#6366f1" : getMutedColor(),
        borderBottom: currentPage === "charts" ? "2px solid #6366f1" : "2px solid transparent"
      }}>Charts</Button>
      <Button variant=ghost @click={navigate("animations")} style={{
        flex: 1, padding: "0.5rem", borderRadius: 0, fontSize: "0.75rem", fontWeight: 600,
        color: currentPage === "animations" ? "#6366f1" : getMutedColor(),
        borderBottom: currentPage === "animations" ? "2px solid #6366f1" : "2px solid transparent"
      }}>Animations</Button>
      <Button variant=ghost @click={navigate("interactive")} style={{
        flex: 1, padding: "0.5rem", borderRadius: 0, fontSize: "0.75rem", fontWeight: 600,
        color: currentPage === "interactive" ? "#6366f1" : getMutedColor(),
        borderBottom: currentPage === "interactive" ? "2px solid #6366f1" : "2px solid transparent"
      }}>Interactive</Button>
    </Box>

    <Box style={{ display: "flex", flex: 1, overflow: "hidden" }}>
    // Sidebar Navigation
    <Nav />

    // Main Content Area
    <Box style={{ flex: 1, display: "flex", flexDirection: "column", overflow: "hidden", minWidth: 0, minHeight: 0 }}>
      // Page Content
      <Box className="softn-page-content" style={{ flex: 1, overflow: "auto", padding: "2rem 2.5rem", minHeight: 0, background: getBgColor() }}>
        <ChartsPage />
        <AnimationsPage />
        <InteractivePage />
      </Box>
    </Box>
    </Box>
  </Box>
</App>
