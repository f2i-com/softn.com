// Services.ui - Services management page with list and detail views

<Stack direction=vertical gap=lg if={currentPage === "services"}>
  // Detail View - shown when a service is selected
  <Stack direction=vertical gap=lg if={selectedItem}>
    <Button variant=ghost size=sm @click=clearSelection style={{ alignSelf: "flex-start", gap: "0.375rem", color: getAccentColor(), fontSize: "0.8rem" }}>
      ← Back to list
    </Button>

    // Service Header Card
    <Card padding=lg style={{ background: darkMode ? "linear-gradient(135deg, #1c1917 0%, #292524 100%)" : "linear-gradient(135deg, #ffffff 0%, #faf9f7 100%)", borderRadius: "16px", border: "1px solid " + getBorderColor() }}>
      <Stack className="softn-mobile-stack" direction=horizontal gap=lg align=center style={{ flexWrap: "wrap" }}>
        <Box style={{ padding: "0.75rem 1rem", background: "linear-gradient(135deg, " + getAccentColor() + ", " + getAccentHover() + ")", borderRadius: "12px", minWidth: "60px", textAlign: "center", flexShrink: 0, boxShadow: "0 2px 10px " + getAccentMuted() }}>
          <Text size=lg fontWeight=bold style={{ color: darkMode ? "#1c1917" : "#ffffff" }}>{selectedItem.data.duration + "m"}</Text>
        </Box>
        <Stack direction=vertical gap=xs style={{ flex: 1, minWidth: 0 }}>
          <Heading level={3} style={{ fontSize: "1.25rem", fontFamily: "'Cormorant Garamond', serif" }}>{selectedItem.data.name}</Heading>
          <Badge variant=secondary>{selectedItem.data.category}</Badge>
        </Stack>
        <Stack direction=vertical align=end gap=xs style={{ flexShrink: 0 }}>
          <Text color=muted size=xs>Price</Text>
          <Text size=lg fontWeight=bold style={{ color: getAccentColor(), fontFamily: "'Cormorant Garamond', serif" }}>{"$" + selectedItem.data.price}</Text>
        </Stack>
      </Stack>
    </Card>

    // Service Details
    <SmartView data={selectedItem.data} fields="name, category, price, duration" layout=card title="Service Details" />
  </Stack>

  // List View - shown when no service is selected
  <Stack direction=vertical gap=lg if={!selectedItem}>
    <Card padding=md style={{ background: getCardBg(), borderRadius: "14px", border: "1px solid " + getBorderColor(), transition: "background 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1)", overflow: "auto" }}>
      <SmartGrid
        data={services}
        columns="name, category, price, duration"
        searchable
        sortable
        pageable
        pageSize={10}
        editable
        delete
        onSelect={selectItem}
        onEdit={editService}
        onDelete={deleteService}
        emptyMessage="No services yet. Click '+ Service' to create your first service."
      />
    </Card>
  </Stack>
</Stack>
