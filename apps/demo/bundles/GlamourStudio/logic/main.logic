  // Data Management Modal
  function openDataModal() {
    showDataModal = true
  }

  function closeDataModal() {
    showDataModal = false
    exportedData = ""
    importData = ""
    confirmClearData = false
  }

  // XDB Data Export/Import
  function exportAllData() {
    let data = {
      clients: db.query("clients"),
      staff: db.query("staff"),
      services: db.query("services"),
      appointments: db.query("appointments"),
      activity: db.query("activity")
    }
    exportedData = JSON.stringify(data, null, 2)
  }

  function copyToClipboard() {
    if (exportedData) {
      navigator.clipboard.writeText(exportedData)
    }
  }

  function setImportData(value) {
    importData = value
  }

  function importAllData() {
    if (!importData) return

    try {
      let parsed = JSON.parse(importData)
      let count = 0

      if (parsed.clients) {
        parsed.clients.forEach(function(r) {
          db.create("clients", r.data || r)
          count = count + 1
        })
      }
      if (parsed.staff) {
        parsed.staff.forEach(function(r) {
          db.create("staff", r.data || r)
          count = count + 1
        })
      }
      if (parsed.services) {
        parsed.services.forEach(function(r) {
          db.create("services", r.data || r)
          count = count + 1
        })
      }
      if (parsed.appointments) {
        parsed.appointments.forEach(function(r) {
          db.create("appointments", r.data || r)
          count = count + 1
        })
      }
      if (parsed.activity) {
        parsed.activity.forEach(function(r) {
          db.create("activity", r.data || r)
          count = count + 1
        })
      }

      logActivity("Data imported", count + " records imported", "success")
      importData = ""
    } catch (e) {
      logActivity("Import failed", "Invalid JSON data", "error")
    }
  }

  function clearAllData() {
    if (!confirmClearData) {
      confirmClearData = true
      return
    }

    let clients = db.query("clients")
    let staff = db.query("staff")
    let services = db.query("services")
    let appointments = db.query("appointments")
    let activity = db.query("activity")

    clients.forEach(function(r) { db.delete(r.id) })
    staff.forEach(function(r) { db.delete(r.id) })
    services.forEach(function(r) { db.delete(r.id) })
    appointments.forEach(function(r) { db.delete(r.id) })
    activity.forEach(function(r) { db.delete(r.id) })

    confirmClearData = false
    closeDataModal()
  }

  function cancelClearData() {
    confirmClearData = false
  }

  // Auto-init: resume sync from localStorage if previously connected
  function _init() {
    let savedRoom = db.getSavedSyncRoom()
    if (savedRoom) {
      syncRoom = savedRoom
      syncConnecting = true
      db.startSync(savedRoom)
    }
  }

  // P2P Sync functions
  function openSyncModal() {
    showSyncModal = true
    refreshSyncStatus()
  }

  function closeSyncModal() {
    showSyncModal = false
  }

  function setSyncRoom(value) {
    if (value && value.target) {
      syncRoom = value.target.value
    } else {
      syncRoom = value
    }
  }

  function copySyncRoom() {
    if (syncRoom) {
      navigator.clipboard.writeText(syncRoom)
    }
  }

  function generateRoomCode() {
    let chars = "abcdefghijklmnopqrstuvwxyz0123456789"
    let code = "glamour-"
    let i = 0
    while (i < 6) {
      code = code + chars.charAt(Math.floor(Math.random() * chars.length))
      i = i + 1
    }
    syncRoom = code
  }

  function joinSync() {
    if (!syncRoom) return
    syncConnecting = true
    syncConnected = false
    db.startSync(syncRoom)
  }

  function leaveSync() {
    db.stopSync(syncRoom)
    syncConnected = false
    syncConnecting = false
    syncPeers = 0
  }

  function refreshSyncStatus() {
    let status = db.getSyncStatus(syncRoom)
    if (status) {
      syncConnected = status.connected
      syncPeers = status.peers
      if (status.connected) {
        syncConnecting = false
      }
    } else if (syncConnecting) {
      // No status returned — sync likely failed to initialize
      syncConnecting = false
    }
  }
