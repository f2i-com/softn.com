{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for SoftN Loader (desktop)",
  "platforms": ["linux", "macOS", "windows"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-title",
    "core:window:allow-set-focus",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "cli:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file"
  ]
}
